# ────────────────────────────────────────────────────────────────────
# EF Core Migrations — scoped .editorconfig
# ────────────────────────────────────────────────────────────────────
# Migration files are machine-generated by EF Core tooling.
# Developers must NEVER hand-edit these files.
#
# This scoped config relaxes style and analysis rules that
# generated code cannot satisfy, while inheriting all other
# settings from the parent .editorconfig hierarchy.
#
# The primary defence is generated_code = true, which causes
# most Roslyn analysers to skip these files automatically.
# Explicit suppressions below cover rules known to still fire
# when EnforceCodeStyleInBuild and TreatWarningsAsErrors are
# active, or where analyser behaviour may vary across SDK
# versions.
# ────────────────────────────────────────────────────────────────────

[*.cs]
generated_code = true

# ── Formatting ────────────────────────────────────────────────────
dotnet_diagnostic.IDE0055.severity = none          # Fix formatting

# ── Style preferences (generated code cannot satisfy) ─────────────
dotnet_diagnostic.IDE0005.severity = none          # Remove unnecessary using
dotnet_diagnostic.IDE0008.severity = none          # Use explicit type instead of var
dotnet_diagnostic.IDE0009.severity = none          # Add this. qualification
dotnet_diagnostic.IDE0011.severity = none          # Add braces
dotnet_diagnostic.IDE0017.severity = none          # Use object initialisers
dotnet_diagnostic.IDE0028.severity = none          # Use collection initialisers
dotnet_diagnostic.IDE0036.severity = none          # Order modifiers
dotnet_diagnostic.IDE0040.severity = none          # Add accessibility modifiers
dotnet_diagnostic.IDE0044.severity = none          # Make field readonly
dotnet_diagnostic.IDE0049.severity = none          # Use language keywords
dotnet_diagnostic.IDE0053.severity = none          # Use expression body for lambdas
dotnet_diagnostic.IDE0058.severity = none          # Remove unnecessary expression value
dotnet_diagnostic.IDE0160.severity = none          # Use block-scoped namespace
dotnet_diagnostic.IDE0290.severity = none          # Use primary constructor
dotnet_diagnostic.IDE0300.severity = none          # Collection expression can be simplified

# ── Documentation ─────────────────────────────────────────────────
dotnet_diagnostic.CS1591.severity = none           # Missing XML comment

# ── Code analysis (common in migration seed data) ─────────────────
dotnet_diagnostic.CA1062.severity = none           # Validate arguments of public methods
dotnet_diagnostic.CA1707.severity = none           # Identifiers should not contain underscores
dotnet_diagnostic.CA1814.severity = none           # Prefer jagged arrays
dotnet_diagnostic.CA1825.severity = none           # Avoid zero-length array allocations
dotnet_diagnostic.CA1861.severity = none           # Avoid constant arrays as arguments

# ── Naming rules (generated code uses EF conventions) ─────────────
dotnet_diagnostic.IDE1006.severity = none          # Naming rule violation